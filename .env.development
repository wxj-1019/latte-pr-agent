# ============================================
# 本地开发环境配置
# 复制为 .env 即可使用
# ============================================

# Database (本地开发使用本地 PostgreSQL)
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@localhost:5432/code_review
SYNC_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/code_review

# Redis (本地开发)
REDIS_URL=redis://localhost:6379/0

# GitHub (开发测试用，生产必须替换)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=dev_secret

# GitLab
GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=dev_secret
GITLAB_URL=https://gitlab.com

# LLM API Keys (至少配置一个)
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=

# App Settings
APP_ENV=development
LOG_LEVEL=DEBUG
MAX_CONCURRENT_REVIEWS=5
ENABLE_REASONER_REVIEW=false

# CORS: 开发环境可留空或设为 *，会自动展开为 localhost:3000/5173 等
CORS_ORIGINS=*

ADMIN_API_KEY=dev_admin_key
