# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/code_review
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/code_review

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub
GITHUB_TOKEN=ghp_xxx
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# GitLab
GITLAB_TOKEN=glpat-xxx
GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret
GITLAB_URL=https://gitlab.com

# LLM APIs
DEEPSEEK_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# App Config
APP_ENV=development
LOG_LEVEL=INFO
MAX_CONCURRENT_REVIEWS=20
ENABLE_REASONER_REVIEW=false
