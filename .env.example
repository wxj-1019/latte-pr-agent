# ============================================
# 环境变量模板
# ============================================
#
# 快速开始：
#   本地开发  ->  确保存在 .env.development（APP_ENV 默认为 development）
#   生产部署  ->  确保存在 .env.production（并填入真实值），或直接在环境中设置变量
#
# 核心规则：
#   - 系统会根据 APP_ENV 自动加载对应的 .env.<environment> 文件
#   - APP_ENV=development 时，CORS_ORIGINS 可留空，自动允许 localhost:3000/5173
#   - APP_ENV=production  时，CORS_ORIGINS 必须显式配置，不能为 *
#
# ============================================

# Database
# 注意：Pydantic Settings 不支持变量插值，DATABASE_URL 中的密码需要手动填写
POSTGRES_PASSWORD=your_secure_password
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password@localhost:5432/code_review
SYNC_DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/code_review

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxx
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# GitLab
GITLAB_TOKEN=glpat-xxxxxxxx
GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret
GITLAB_URL=https://gitlab.com

# LLM API Keys (至少配置一个)
DEEPSEEK_API_KEY=sk-xxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx
QWEN_API_KEY=sk-xxxxxxxx

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
MAX_CONCURRENT_REVIEWS=20
ENABLE_REASONER_REVIEW=false

# CORS  origins，多个用逗号分隔
# 开发环境可设为 * 或留空，自动展开为 localhost
# 生产环境必须显式配置，例如 https://your-domain.com
CORS_ORIGINS=*

ADMIN_API_KEY=your_admin_api_key

# 项目克隆路径配置
# 默认 ./repos（项目目录下），可改为绝对路径避免与 git 仓库混淆
# Windows 示例: REPOS_BASE_PATH=C:/latte-repos
# Linux/macOS 示例: REPOS_BASE_PATH=/var/latte-repos
REPOS_BASE_PATH=./repos
