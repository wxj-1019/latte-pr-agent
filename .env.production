# ============================================
# 生产环境配置模板
# 复制为 .env 并填入真实值后使用
# ============================================

# Database (生产环境必须使用强密码)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@postgres:5432/code_review
SYNC_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/code_review

# Redis
REDIS_URL=redis://redis:6379/0

# GitHub (必须填入真实 Token)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# GitLab
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret
GITLAB_URL=https://gitlab.com

# LLM API Keys (至少配置一个)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# App Settings
APP_ENV=production
LOG_LEVEL=INFO
MAX_CONCURRENT_REVIEWS=20
ENABLE_REASONER_REVIEW=false

# CORS: 生产环境必须显式配置，不能为 * 或空
# 多个域名用逗号分隔
CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com

ADMIN_API_KEY=CHANGE_ME_STRONG_ADMIN_KEY
